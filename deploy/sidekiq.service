[Unit]
Description=Sidekiq background job worker for Shiksha Portal
After=network.target redis.service
Wants=redis.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/var/www/shikshaportal/backend
Environment=RAILS_ENV=production
EnvironmentFile=/var/www/shikshaportal/backend/.env
ExecStart=/usr/local/bin/bundle exec sidekiq -C config/sidekiq.yml
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
