# Frontend environment (T17)
# Copy to .env.local for overrides — never commit .env.local to git.
#
#   cp .env.example .env.local

# Override API base URL (optional — default uses same hostname on port 3000)
# VITE_API_URL=http://localhost:3000/api/v1

# Production build: set in CI or on server before npm run build
# VITE_API_URL=https://greenvalley.shikshaportal.in/api/v1
