# Staging environment template (T17)
# Copy to backend/.env on the staging VM — never commit .env to git.
#
#   cp .env.staging.example .env
#   bin/check-env

RAILS_ENV=staging
APP_HOST=staging.shikshaportal.in
FRONTEND_ORIGIN=https://staging.shikshaportal.in

# Generate with: rails secret  (run twice for JWT_SECRET_KEY)
SECRET_KEY_BASE=
JWT_SECRET_KEY=
JWT_EXPIRY_HOURS=24
SUPER_ADMIN_API_KEY=

# Separate staging database — never point at production
DATABASE_URL=postgres://shikshaportal_staging:PASSWORD@localhost:5432/shikshaportal_staging

MAILER_FROM=noreply@staging.shikshaportal.in

# Optional — same providers as production, use staging keys where possible
# CURSOR_API_KEY=
# ANTHROPIC_API_KEY=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=shikshaportal-staging-uploads
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

RAILS_LOG_LEVEL=debug
