<%= t("mailers.student_credentials.greeting", name: @student.name) %>

<%= t("mailers.student_credentials.intro", school: @school.name) %>

<%= t("mailers.student_credentials.login_url", url: @login_url) %>
<%= t("mailers.student_credentials.email", email: @student.email) %>
<%= t("mailers.student_credentials.password", password: @temporary_password) %>

<%= t("mailers.student_credentials.class_info", class_name: @student.class_name, section: @student.section) %>
<%= t("mailers.student_credentials.roll_number", roll_number: @student.roll_number) %>

<%= t("mailers.student_credentials.change_password") %>

<%= t("mailers.student_credentials.signature") %>
