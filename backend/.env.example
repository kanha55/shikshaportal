# Shiksha Portal — Backend environment (T17)
# Copy to .env and fill in values. Never commit .env to git.
#
#   cp .env.example .env          # local development
#   cp .env.staging.example .env  # staging server
#
# Validate before deploy: bin/check-env

# --- Core ---
RAILS_ENV=development
APP_HOST=localhost
FRONTEND_ORIGIN=http://localhost:5173

# --- Auth / JWT (use strong random values in production) ---
SECRET_KEY_BASE=dev-local-secret-change-in-production
JWT_SECRET_KEY=dev-jwt-secret-change-in-production
JWT_EXPIRY_HOURS=24

# Super admin API key for POST /api/v1/admin/schools
SUPER_ADMIN_API_KEY=dev-super-admin-key

# --- Database ---
# Local dev uses database.yml defaults; production/staging require DATABASE_URL.
# DATABASE_URL=postgres://user:pass@localhost:5432/shikshaportal_development

# --- Email ---
MAILER_FROM=noreply@shikshaportal.test
# RESEND_API_KEY=re_xxxxxxxx
# SMTP_ADDRESS=smtp.resend.com
# SMTP_USERNAME=resend
# SMTP_PASSWORD=re_xxxxxxxx

# --- AI Parent Communicator (T15) ---
# Production (Railway): set ANTHROPIC_API_KEY for reliable Claude drafts.
# CURSOR_API_KEY uses the Cursor Agents API and often fails on headless servers;
# if both fail, the app falls back to a template draft (no keys required).
CURSOR_API_KEY=
# CURSOR_AI_MODEL=composer-2.5
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- Cloudflare R2 file storage (T10) — all four required together in production ---
# Dev uses local disk; production sets all R2_* vars or files stay on local disk.
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=shikshaportal-uploads
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# --- Server tuning (optional) ---
# RAILS_LOG_LEVEL=info
# RAILS_MAX_THREADS=3
# PORT=3000
